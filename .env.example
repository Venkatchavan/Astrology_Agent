# Environment Variables
# Copy this file to .env and fill in your actual API keys

# OpenAI API Key (for LLM synthesis and embeddings)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (alternative to OpenAI)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: HuggingFace API Token (for using HuggingFace models)
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your-huggingface-token-here

# Optional: LangSmith (for tracing and debugging)
# Get your key from: https://smith.langchain.com/
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=astrological-agent
